type: install
version: 1.1

name: Hermes Agent
displayName: Hermes Agent
description: Hermes Agent is an open-source AI agent by Nous Research — persistent memory, skills, multi-platform gateway, and 20+ LLM providers. Runs as an OpenAI-compatible API server.
homepage: https://hermes-agent.nousresearch.com/
logo: https://raw.githubusercontent.com/NousResearch/hermes-agent/main/website/static/img/logo.png
categories:
  - apps/dev-and-admin-tools

ssl: true
skipNodeEmails: true

globals:
  gatewayToken: ha_${fn.uuid}
  gatewayPassword: pw_${fn.password}
  publicPort: 80
  containerPort: 8642
  stateDir: /data/hermes
  runtimeImage: python:3.11-slim

nodes:
  - nodeGroup: cp
    nodeType: docker
    displayName: Hermes Agent Docker Engine
    image: jelastic/docker-ce:latest
    cloudlets: 16
    fixedCloudlets: 1
    count: 1
    extip: false
    isRedeploySupport: true
    ports:
      - ${globals.publicPort}
    volumes:
      - /var/lib/docker
      - ${globals.stateDir}

onInstall:
  - cmd[cp]: |-
      set -eu

      STATE_DIR="${globals.stateDir}"
      PUBLIC_PORT="${globals.publicPort}"
      CONTAINER_PORT="${globals.containerPort}"
      RUNTIME_IMAGE="${globals.runtimeImage}"

      echo "Waiting for Docker Engine..."
      for i in $(seq 1 60); do
        if docker info >/dev/null 2>&1; then
          break
        fi
        sleep 2
      done
      docker info >/dev/null

      echo "Preparing persistent directories..."
      mkdir -p "${STATE_DIR}/data"

      echo "Pulling Python runtime image..."
      docker pull "${RUNTIME_IMAGE}"

      echo "Writing entrypoint script..."
      cat > "${STATE_DIR}/entrypoint.sh" <<'ENTRYEOF'
      #!/bin/sh
      set -eu

      HERMES_HOME="/root/.hermes"

      echo "[entrypoint] Installing system dependencies..."
      apt-get update -qq >/dev/null 2>&1
      DEBIAN_FRONTEND=noninteractive apt-get install -y -qq --no-install-recommends \
        curl git ca-certificates >/dev/null 2>&1

      echo "[entrypoint] Installing Node.js 22..."
      curl -fsSL https://deb.nodesource.com/setup_22.x | bash - >/dev/null 2>&1
      DEBIAN_FRONTEND=noninteractive apt-get install -y -qq --no-install-recommends nodejs >/dev/null 2>&1

      echo "[entrypoint] Installing uv..."
      curl -LsSf https://astral.sh/uv/install.sh | sh >/dev/null 2>&1
      export PATH="/root/.local/bin:$PATH"

      echo "[entrypoint] Installing hermes-agent..."
      uv tool install hermes-agent

      mkdir -p "${HERMES_HOME}"

      GATEWAY_TOKEN="__GATEWAY_TOKEN__"
      CONTAINER_PORT="__CONTAINER_PORT__"

      cat > "${HERMES_HOME}/config.yaml" <<CFGEOF
      model:
        default: openrouter/auto
        provider: openrouter

      agent:
        max_turns: 90

      terminal:
        timeout: 300

      compression:
        enabled: true
        threshold: 0.50
        target_ratio: 0.20

      memory:
        memory_enabled: true
        user_profile_enabled: true

      platforms:
        api_server:
          enabled: true
          extra:
            host: 0.0.0.0
            port: ${CONTAINER_PORT}
            key: ${GATEWAY_TOKEN}
            cors_origins: '*'
            model_name: hermes-agent
      CFGEOF

      cat > "${HERMES_HOME}/.env" <<ENVEOF
      OPENROUTER_API_KEY=${OPENROUTER_API_KEY:-}
      ANTHROPIC_API_KEY=${ANTHROPIC_API_KEY:-}
      OPENAI_API_KEY=${OPENAI_API_KEY:-}
      GEMINI_API_KEY=${GEMINI_API_KEY:-}
      ENVEOF

      echo "[entrypoint] Starting Hermes Agent gateway..."
      exec hermes gateway run
      ENTRYEOF
      chmod +x "${STATE_DIR}/entrypoint.sh"

      # Inject real token value into entrypoint
      sed -i "s|__GATEWAY_TOKEN__|${globals.gatewayToken}|g" "${STATE_DIR}/entrypoint.sh"
      sed -i "s|__CONTAINER_PORT__|${globals.containerPort}|g" "${STATE_DIR}/entrypoint.sh"

      echo "Stopping old container if present..."
      docker rm -f hermes >/dev/null 2>&1 || true

      echo "Starting Hermes Agent container..."
      docker run -d \
        --name hermes \
        --restart unless-stopped \
        -u root \
        -p "${PUBLIC_PORT}:${CONTAINER_PORT}" \
        -v "${STATE_DIR}/data:/root/.hermes" \
        -v "${STATE_DIR}/entrypoint.sh:/entrypoint.sh:ro" \
        -e OPENROUTER_API_KEY="${settings.openrouterApiKey:-}" \
        -e ANTHROPIC_API_KEY="${settings.anthropicApiKey:-}" \
        -e OPENAI_API_KEY="${settings.openaiApiKey:-}" \
        -e GEMINI_API_KEY="${settings.geminiApiKey:-}" \
        "${RUNTIME_IMAGE}" \
        sh /entrypoint.sh

      echo "Waiting for Hermes Agent to respond (this may take 3-5 minutes)..."
      for i in $(seq 1 240); do
        if curl -fsS "http://127.0.0.1:${PUBLIC_PORT}/health" >/dev/null 2>&1; then
          echo "Hermes Agent is UP"
          break
        fi
        sleep 2
      done

      curl -fsS "http://127.0.0.1:${PUBLIC_PORT}/health" 2>&1 || echo "Health check not yet available"
      docker ps --filter name=hermes

settings:
  - name: OpenRouter API Key
    type: string
    id: openrouterApiKey
    placeholder: sk-or-...
    tooltip: API key for OpenRouter (recommended — gives access to 200+ models)
  - name: Anthropic API Key
    type: string
    id: anthropicApiKey
    placeholder: sk-ant-...
    tooltip: API key for Anthropic (Claude models)
  - name: OpenAI API Key
    type: string
    id: openaiApiKey
    placeholder: sk-...
    tooltip: API key for OpenAI (GPT models)
  - name: Google Gemini API Key
    type: string
    id: geminiApiKey
    placeholder: AIza...
    tooltip: API key for Google Gemini

addons:
  - id: update-hermes-latest
    name: Update Hermes to Latest
    onInstall:
      - cmd[cp]: |-
          set -eu
          docker exec hermes sh -lc 'export PATH="/root/.local/bin:$PATH" && uv tool upgrade hermes-agent'
          docker restart hermes
          for i in $(seq 1 120); do
            if docker exec hermes sh -lc 'hermes --version' >/dev/null 2>&1; then
              break
            fi
            sleep 2
          done
          docker exec hermes sh -lc 'hermes --version' || true

startPage: https://${env.domain}/

success: |
  Hermes Agent has been installed.

  ═══════════════════════════════════════
  ACCESS CARD
  ═══════════════════════════════════════

  API endpoint:
    https://${env.domain}/v1

  Gateway token (bearer key):
    ${globals.gatewayToken}

  Password:
    ${globals.gatewayPassword}

  Health check:
    https://${env.domain}/health

  Models endpoint:
    https://${env.domain}/v1/models

  ═══════════════════════════════════════

  Keep these values somewhere safe. The token is your API bearer key.

  HOW TO USE:

  * OpenAI-compatible API — point any OpenAI client to:
      Base URL:  https://${env.domain}/v1
      API Key:   ${globals.gatewayToken}
      Model:     hermes-agent

  * Hermes Desktop — connect in remote mode:
      URL:       https://${env.domain}
      Token:     ${globals.gatewayToken}

  * curl test:
      curl -sS https://${env.domain}/v1/chat/completions \
        -H "Authorization: Bearer ${globals.gatewayToken}" \
        -H 'Content-Type: application/json' \
        -d '{"model":"hermes-agent","messages":[{"role":"user","content":"Hello!"}]}'

  NOTES:

  * Default model is openrouter/auto (200+ models via OpenRouter).
  * Set your API keys in the install settings or edit the .env file inside the container.
  * The Add-ons tab includes an "Update Hermes to Latest" action for upgrades.
  * Built-in SSL is enabled.
  * The node does not use a public IP.
  * Docker restart policy is set to unless-stopped.
  * First start takes 3-5 minutes (installing Python deps + Node.js + hermes-agent).
