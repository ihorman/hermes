type: install
version: 4.0

name: Hermes Agent
displayName: Hermes Agent
description: Hermes Agent by Nous Research — open-source AI agent with persistent memory, skills, and 20+ LLM providers. OpenAI-compatible API server.
homepage: https://hermes-agent.nousresearch.com/
logo: https://raw.githubusercontent.com/NousResearch/hermes-agent/main/website/static/img/logo.png
categories:
  - apps/dev-and-admin-tools

ssl: true
skipNodeEmails: true

globals:
  gatewayToken: ha_${fn.uuid}
  gatewayPassword: pw_${fn.password}
  publicPort: 80
  containerPort: 8642
  stateDir: /tmp/hermes
  hermesVersion: latest
  runtimeImage: hermes-py:3.12-alpine
  runtimeSource: docker.io/library/python:3.12-alpine

nodes:
  - nodeGroup: cp
    nodeType: docker
    displayName: Hermes Agent
    image: jelastic/docker-ce:latest
    cloudlets: 16
    fixedCloudlets: 2
    count: 1
    extip: false
    isRedeploySupport: true
    ports:
      - ${globals.publicPort}
    volumes:
      - /var/lib/docker

onInstall:
  - cmd[cp]: |-
      set -eu
      STATE_DIR="${globals.stateDir}"
      mkdir -p "${STATE_DIR}"

      echo "Waiting for Docker..."
      for i in $(seq 1 60); do docker info >/dev/null 2>&1 && break; sleep 2; done

      echo "Loading Python image via skopeo..."
      if command -v skopeo >/dev/null 2>&1; then
        true
      elif command -v yum >/dev/null 2>&1; then
        yum install -y --skip-broken skopeo curl ca-certificates || true
      fi
      tmp_archive="$(mktemp /tmp/hermes.XXXXXX.tar)"
      skopeo copy --format v2s2 "docker://${globals.runtimeSource}" "docker-archive:${tmp_archive}:${globals.runtimeImage}"
      docker load -i "${tmp_archive}"
      rm -f "${tmp_archive}"

      echo "Writing start.sh..."
      cat > "${STATE_DIR}/start.sh" <<'EOF'
      #!/bin/sh
      set -eu
      echo "[start] Installing curl + git..."
      apk add --no-cache curl git ca-certificates || true
      if ! command -v curl >/dev/null 2>&1; then
        echo "[start] ERROR: curl not installed"
        exit 1
      fi

      echo "[start] Installing uv + hermes-agent..."
      curl -LsSf https://astral.sh/uv/install.sh | sh >/dev/null 2>&1
      export PATH="/root/.local/bin:$PATH"
      uv tool install hermes-agent__VER__ --with aiohttp

      mkdir -p /root/.hermes
      cat > /root/.hermes/config.yaml <<CFGEOF
      model:
        default: openrouter/auto
        provider: openrouter
      agent:
        max_turns: 90
      terminal:
        timeout: 300
      compression:
        enabled: true
        threshold: 0.50
        target_ratio: 0.20
      memory:
        memory_enabled: true
        user_profile_enabled: true
      platforms:
        api_server:
          enabled: true
          extra:
            host: 0.0.0.0
            port: __PORT__
            key: __TOKEN__
            cors_origins: '*'
            model_name: hermes-agent
      CFGEOF

      cat > /root/.hermes/.env <<ENVEOF
      OPENROUTER_API_KEY=${OPENROUTER_API_KEY:-}
      ANTHROPIC_API_KEY=${ANTHROPIC_API_KEY:-}
      OPENAI_API_KEY=${OPENAI_API_KEY:-}
      GEMINI_API_KEY=${GEMINI_API_KEY:-}
      ENVEOF

      echo "[start] Launching hermes gateway..."
      export TMPDIR=/tmp
      exec hermes gateway run
      EOF

      chmod +x "${STATE_DIR}/start.sh"

      # Inject real values via sed
      sed -i "s|__TOKEN__|${globals.gatewayToken}|g" "${STATE_DIR}/start.sh"
      sed -i "s|__PORT__|${globals.containerPort}|g" "${STATE_DIR}/start.sh"
      if [ "${globals.hermesVersion}" = "latest" ]; then
        sed -i "s|__VER__||g" "${STATE_DIR}/start.sh"
      else
        sed -i "s|__VER__|==${globals.hermesVersion}|g" "${STATE_DIR}/start.sh"
      fi

      docker rm -f hermes >/dev/null 2>&1 || true

      echo "Starting container..."
      docker run -d \
        --name hermes \
        --restart unless-stopped \
        -u root \
        -p "${globals.publicPort}:${globals.containerPort}" \
        --tmpfs /tmp:rw,size=256m,exec \
        --tmpfs /root/.hermes:rw,size=256m,exec \
        -v "${STATE_DIR}/start.sh:/start.sh:ro" \
        -e OPENROUTER_API_KEY="${settings.openrouterApiKey:-}" \
        -e ANTHROPIC_API_KEY="${settings.anthropicApiKey:-}" \
        -e OPENAI_API_KEY="${settings.openaiApiKey:-}" \
        -e GEMINI_API_KEY="${settings.geminiApiKey:-}" \
        -e HERMES_HOME="/root/.hermes" \
        -e TMPDIR="/tmp" \
        -w "/root/.hermes" \
        "${globals.runtimeImage}" \
        sh /start.sh

      echo "Done. Container is starting — hermes gateway will be ready in ~3 minutes."

settings:
  - name: OpenRouter API Key
    type: string
    id: openrouterApiKey
    placeholder: sk-or-...
    tooltip: API key for OpenRouter (recommended — 200+ models)
  - name: Anthropic API Key
    type: string
    id: anthropicApiKey
    placeholder: sk-ant-...
    tooltip: API key for Anthropic (Claude)
  - name: OpenAI API Key
    type: string
    id: openaiApiKey
    placeholder: sk-...
    tooltip: API key for OpenAI
  - name: Google Gemini API Key
    type: string
    id: geminiApiKey
    placeholder: AIza...
    tooltip: API key for Google Gemini

addons:
  - id: update-hermes-latest
    name: Update Hermes to Latest
    onInstall:
      - cmd[cp]: |-
          set -eu
          docker exec hermes sh -lc 'export PATH="/root/.local/bin:$PATH" && uv tool upgrade hermes-agent'
          docker restart hermes

startPage: https://${env.domain}/

success: |
  Hermes Agent has been installed.

  API endpoint:  https://${env.domain}/v1
  Token:         ${globals.gatewayPassword}
  Health:        https://${env.domain}/health
  Models:        https://${env.domain}/v1/models

  curl test:
    curl -sS https://${env.domain}/v1/chat/completions \
      -H "Authorization: Bearer ${globals.gatewayToken}" \
      -H 'Content-Type: application/json' \
      -d '{"model":"hermes-agent","messages":[{"role":"user","content":"Hello!"}]}'

  Default model: openrouter/auto (200+ models). Set API keys in install settings.
  Gateway will be ready ~3 min after install. Add-ons tab has "Update to Latest".
