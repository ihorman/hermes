type: install
version: 2.0

name: Hermes Agent
displayName: Hermes Agent
description: Hermes Agent is an open-source AI agent by Nous Research — persistent memory, skills, multi-platform gateway, and 20+ LLM providers. Runs as an OpenAI-compatible API server.
homepage: https://hermes-agent.nousresearch.com/
logo: https://raw.githubusercontent.com/NousResearch/hermes-agent/main/website/static/img/logo.png
categories:
  - apps/dev-and-admin-tools

ssl: true
skipNodeEmails: true

globals:
  gatewayToken: ha_${fn.uuid}
  gatewayPassword: pw_${fn.password}
  publicPort: 80
  hermesVersion: latest

nodes:
  - nodeGroup: cp
    nodeType: docker
    displayName: Hermes Agent
    image: jelastic/docker-ce:latest
    cloudlets: 16
    fixedCloudlets: 1
    count: 1
    extip: false
    isRedeploySupport: true
    ports:
      - ${globals.publicPort}

onInstall:
  - cmd[cp]: |-
      set -eu

      GATEWAY_TOKEN="${globals.gatewayToken}"
      GATEWAY_PASSWORD="${globals.gatewayPassword}"
      PUBLIC_PORT="${globals.publicPort}"
      HERMES_VERSION="${globals.hermesVersion}"

      echo "=== Installing Python 3.11 via Miniconda ==="
      curl -fsSL https://repo.anaconda.com/miniconda/Miniconda3-latest-Linux-x86_64.sh -o /tmp/miniconda.sh
      bash /tmp/miniconda.sh -b -p /opt/miniconda
      rm -f /tmp/miniconda.sh
      export PATH="/opt/miniconda/bin:$PATH"

      conda create -y -n hermes python=3.11
      export PATH="/opt/miniconda/envs/hermes/bin:$PATH"

      echo "=== Installing hermes-agent ==="
      if [ "${HERMES_VERSION}" = "latest" ]; then
        pip install hermes-agent
      else
        pip install "hermes-agent==${HERMES_VERSION}"
      fi

      echo "=== Configuring Hermes ==="
      HERMES_HOME="/root/.hermes"
      mkdir -p "${HERMES_HOME}"

      cat > "${HERMES_HOME}/config.yaml" <<'CFGEOF'
      model:
        default: openrouter/auto
        provider: openrouter

      agent:
        max_turns: 90

      terminal:
        timeout: 300

      compression:
        enabled: true
        threshold: 0.50
        target_ratio: 0.20

      memory:
        memory_enabled: true
        user_profile_enabled: true

      platforms:
        api_server:
          enabled: true
          extra:
            host: 0.0.0.0
            port: __PUBLIC_PORT__
            key: __GATEWAY_TOKEN__
            cors_origins: '*'
            model_name: hermes-agent
      CFGEOF

      # Inject real values
      sed -i "s|__PUBLIC_PORT__|${PUBLIC_PORT}|g" "${HERMES_HOME}/config.yaml"
      sed -i "s|__GATEWAY_TOKEN__|${GATEWAY_TOKEN}|g" "${HERMES_HOME}/config.yaml"

      cat > "${HERMES_HOME}/.env" <<ENVEOF
      OPENROUTER_API_KEY=${settings.openrouterApiKey:-}
      ANTHROPIC_API_KEY=${settings.anthropicApiKey:-}
      OPENAI_API_KEY=${settings.openaiApiKey:-}
      GEMINI_API_KEY=${settings.geminiApiKey:-}
      ENVEOF

      echo "=== Starting Hermes Agent ==="
      export HERMES_HOME="/root/.hermes"
      nohup hermes gateway run > /var/log/hermes-gateway.log 2>&1 &
      echo $! > /var/run/hermes-gateway.pid

      echo "Waiting for Hermes Agent to respond..."
      for i in $(seq 1 120); do
        if curl -fsS "http://127.0.0.1:${PUBLIC_PORT}/health" >/dev/null 2>&1; then
          echo "Hermes Agent is UP after $((i*2)) seconds"
          break
        fi
        sleep 2
      done

      curl -fsS "http://127.0.0.1:${PUBLIC_PORT}/health" 2>&1 || echo "Health check not yet available"
      echo "PID: $(cat /var/run/hermes-gateway.pid 2>/dev/null || echo 'unknown')"

settings:
  - name: OpenRouter API Key
    type: string
    id: openrouterApiKey
    placeholder: sk-or-...
    tooltip: API key for OpenRouter (recommended — gives access to 200+ models)
  - name: Anthropic API Key
    type: string
    id: anthropicApiKey
    placeholder: sk-ant-...
    tooltip: API key for Anthropic (Claude models)
  - name: OpenAI API Key
    type: string
    id: openaiApiKey
    placeholder: sk-...
    tooltip: API key for OpenAI (GPT models)
  - name: Google Gemini API Key
    type: string
    id: geminiApiKey
    placeholder: AIza...
    tooltip: API key for Google Gemini

addons:
  - id: update-hermes-latest
    name: Update Hermes to Latest
    onInstall:
      - cmd[cp]: |-
          set -eu
          export PATH="/opt/miniconda/envs/hermes/bin:/opt/miniconda/bin:$PATH"
          pip install --upgrade hermes-agent
          if [ -f /var/run/hermes-gateway.pid ]; then
            kill "$(cat /var/run/hermes-gateway.pid)" 2>/dev/null || true
            sleep 2
          fi
          export HERMES_HOME="/root/.hermes"
          nohup hermes gateway run > /var/log/hermes-gateway.log 2>&1 &
          echo $! > /var/run/hermes-gateway.pid
          for i in $(seq 1 60); do
            if curl -fsS "http://127.0.0.1:${globals.publicPort}/health" >/dev/null 2>&1; then
              break
            fi
            sleep 2
          done
          hermes --version || true

startPage: https://${env.domain}/

success: |
  Hermes Agent has been installed.

  ═══════════════════════════════════════
  ACCESS CARD
  ═══════════════════════════════════════

  API endpoint:
    https://${env.domain}/v1

  Gateway token (bearer key):
    ${globals.gatewayToken}

  Password:
    ${globals.gatewayPassword}

  Health check:
    https://${env.domain}/health

  Models endpoint:
    https://${env.domain}/v1/models

  ═══════════════════════════════════════

  Keep these values somewhere safe. The token is your API bearer key.

  HOW TO USE:

  * OpenAI-compatible API — point any OpenAI client to:
      Base URL:  https://${env.domain}/v1
      API Key:   ${globals.gatewayToken}
      Model:     hermes-agent

  * Hermes Desktop — connect in remote mode:
      URL:       https://${env.domain}
      Token:     ${globals.gatewayToken}

  * curl test:
      curl -sS https://${env.domain}/v1/chat/completions \
        -H "Authorization: Bearer ${globals.gatewayToken}" \
        -H 'Content-Type: application/json' \
        -d '{"model":"hermes-agent","messages":[{"role":"user","content":"Hello!"}]}'

  NOTES:

  * Default model is openrouter/auto (200+ models via OpenRouter).
  * Set your API keys in the install settings or edit ~/.hermes/.env on the node.
  * The Add-ons tab includes an "Update Hermes to Latest" action for upgrades.
  * Built-in SSL is enabled.
  * First start takes ~3-5 minutes (installing Miniconda + Python 3.11 + hermes-agent).
